{
    "name": "alvaro-estrada-dev/unraid-netbird-utils",
    "description": "Netbird configuration",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Netbird\\": "unraid-netbird-utils/"
        }
    },
    "authors": [
        {
            "name": "Alvaro Estrada"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "sort-packages": true,
        "bin-dir": "../../../../../vendor/bin/"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/dkaser/unraid-utils.git"
        }
    ],
    "require": {
        "edacerton/plugin-utils": "^1.0",
        "rlanvin/php-ip": "^3.0",
        "php": ">=8.3"
    }
}